rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------
    // POSTS (deprecated — kept during migration)
    // ----------------------------------------
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // ----------------------------------------
    // USER PROFILES
    // ----------------------------------------
    match /users/{userId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow update, delete, write: if request.auth != null
                                   && request.auth.uid == userId;
    }

    // ----------------------------------------
    // INVITES
    // ----------------------------------------
    match /invites/{inviteId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "social-admin";
    }

    // ----------------------------------------
    // HIKES (deprecated — kept during migration)
    // ----------------------------------------
    match /{anyPath=**}/hikes {
      allow list: if request.auth != null;
    }

    match /{anyPath=**}/hikes/{hikeId} {
      allow get: if resource.data.public == true
                 || (request.auth != null && request.auth.uid == resource.data.owner.uid);
      allow list: if true;
      allow create: if request.auth != null
                    && request.resource.data.owner is map
                    && request.resource.data.owner.uid == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.createdAt != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.owner.uid;
    }

    // ----------------------------------------
    // ACTIVITIES (replaces hikes)
    // ----------------------------------------

    // CollectionGroup list — allow public activity feed
    match /{anyPath=**}/activities {
      allow list: if resource.data.privacy == "public" || (request.auth != null && request.auth.uid == resource.data.ownerId);
    }

    match /users/{uid}/activities/{activityId} {
      // GET: public activities OR owner
      allow get: if resource.data.privacy == "public"
                 || (request.auth != null && request.auth.uid == resource.data.ownerId);

      // LIST: owner can list their own subcollection; public feed uses collection group
      allow list: if request.auth != null && request.auth.uid == uid;

      // CREATE: authenticated, must own the activity
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.title is string;

      // UPDATE / DELETE: owner only
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }

    // ----------------------------------------
    // ADVENTURES
    // ----------------------------------------
    match /users/{uid}/adventures/{adventureId} {
      allow get: if resource.data.privacy == "public"
                 || (request.auth != null && request.auth.uid == resource.data.ownerId);

      allow list: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.title is string;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }

    // ----------------------------------------
    // GEAR
    // ----------------------------------------
    match /users/{uid}/gear/{gearId} {
      // Gear is private — owner only
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }
  }
}
