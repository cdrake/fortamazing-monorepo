rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // hikes/{uid}/{hikeId}/...
    match /hikes/{uid}/{hikeId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if (resource != null && resource.metadata.public == "true")
                  || (request.auth != null && request.auth.uid == uid);
    }

    // optional alternate path users/{uid}/hikes/{hikeId}/...
    match /users/{uid}/hikes/{hikeId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if (resource != null && resource.metadata.public == "true")
                  || (request.auth != null && request.auth.uid == uid);
    }

    // activities/{uid}/{activityId}/...
    match /activities/{uid}/{activityId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if (resource != null && resource.metadata.public == "true")
                  || (request.auth != null && request.auth.uid == uid);
    }

    // gear/{uid}/{gearId}/... (owner-only)
    match /gear/{uid}/{gearId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // profile_pictures/{uid}/...
    match /profile_pictures/{uid}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if true;
    }

    // default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
